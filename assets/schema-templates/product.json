{
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "{{Product name}}",
  "image": "{{https://example.com/product.jpg}}",
  "description": "{{Specific, quantified description}}",
  "brand": {
    "@type": "Brand",
    "name": "{{Brand}}"
  },
  "offers": {
    "@type": "Offer",
    "url": "{{https://example.com/product}}",
    "priceCurrency": "USD",
